# ============================================
# Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control!

# ============================================
# DATABASE - MongoDB Atlas
# ============================================
# Get from MongoDB Atlas dashboard
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hiresense?retryWrites=true&w=majority

# ============================================
# VECTOR DATABASE - Endee
# ============================================
# Get from Endee dashboard at https://endee.io
ENDEE_URL=https://api.endee.io
ENDEE_API_KEY=your_endee_api_key_here

# ============================================
# AI SERVICES - Google Gemini
# ============================================
# Get API key from https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# AUTHENTICATION - JWT
# ============================================
# Generate a strong random string for JWT signing
# Example: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_change_this_in_production

# ============================================
# FRONTEND - CORS
# ============================================
# URL where React frontend is running
# Development: http://localhost:5173
# Production: https://yourdomain.com
CLIENT_URL=http://localhost:5173

# ============================================
# AUDIO GENERATION - Optional (Murf AI)
# ============================================
# Get API key from https://www.murf.ai
# Comment out if not using audio generation
MURF_API_KEY=your_murf_api_key_here

# ============================================
# SERVER CONFIGURATION
# ============================================
# Port where backend server runs
PORT=5000

# Node environment
NODE_ENV=development

# ============================================
# OPTIONAL: Analytics & Monitoring
# ============================================
# Uncomment if using monitoring services
# SENTRY_DSN=your_sentry_dsn_here
# DATADOG_API_KEY=your_datadog_key_here
